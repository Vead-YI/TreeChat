# TreeChat Environment Variables

# DeepSeek API Key (required)
DEEPSEEK_API_KEY=sk-your-api-key-here

# Database (optional, defaults to SQLite)
# DATABASE_URL=sqlite:///./treechat.db
# or for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/treechat

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO
